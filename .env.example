# GitHub Personal Access Token with `repo` and `workflow` scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Template repo owner (default: ZiWeiWilly)
TEMPLATE_OWNER=ZiWeiWilly

# Template repo name (default: microsite-template)
TEMPLATE_REPO=microsite-template

# Target owner for new repos (default: same as TEMPLATE_OWNER)
TARGET_OWNER=ZiWeiWilly

# Cloudflare Pages — for auto-deploy + custom domain binding
# Account ID: Cloudflare Dashboard → right sidebar
CLOUDFLARE_ACCOUNT_ID=
# API Token: needs "Cloudflare Pages: Edit" permission
CLOUDFLARE_API_TOKEN=
