# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application)
# Authorized redirect URI: http://localhost:3002/api/auth/callback/google (dev)
#                          https://<your-domain>/api/auth/callback/google (prod)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx

# NextAuth secret — generate with: npx auth secret
AUTH_SECRET=

# GitHub Personal Access Token with `repo` and `workflow` scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Template repo owner (default: ZiWeiWilly)
TEMPLATE_OWNER=ZiWeiWilly

# Template repo name (default: microsite-template)
TEMPLATE_REPO=microsite-template

# Target owner for new repos (default: same as TEMPLATE_OWNER)
TARGET_OWNER=ZiWeiWilly

# Cloudflare Pages — for auto-deploy + custom domain binding
# Account ID: Cloudflare Dashboard → right sidebar
CLOUDFLARE_ACCOUNT_ID=
# API Token: needs "Cloudflare Pages: Edit" permission
CLOUDFLARE_API_TOKEN=

# OpenRouter API Key — https://openrouter.ai/keys
OPENROUTER_API_KEY=
